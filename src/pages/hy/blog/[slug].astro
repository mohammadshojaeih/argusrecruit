---
import { getPosts } from '../../../lib/sanity.js';
import { toHTML } from '@portabletext/to-html';
import SiteHead from '../../../components/SiteHead.astro';
import SharedCSS from '../../../components/SharedCSS.astro';
import SiteNav from '../../../components/SiteNav.astro';

export async function getStaticPaths() {
  const posts = await getPosts('hy');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const bodyHtml = Array.isArray(post.body) ? toHTML(post.body) : (post.body || '');
---
<!DOCTYPE html>
<html lang="hy">
<head>
  <SiteHead title={post.title + ' — ArgusRecruit'} description={post.excerpt} lang="hy" />
  <SharedCSS />
  <style>
    .post-hero { padding: 160px 32px 50px; max-width: 820px; margin: 0 auto; }
    .post-tag { display: inline-block; font-size: 11px; letter-spacing: 3px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; margin-bottom: 18px; }
    h1 { font-family: 'Space Grotesk',sans-serif; font-size: clamp(30px,5vw,50px); font-weight: 500; text-transform: uppercase; letter-spacing: -0.5px; line-height: 1.1; margin-bottom: 24px; }
    .meta { font-size: 13px; color: rgba(255,255,255,0.55); letter-spacing: 0.5px; padding-bottom: 32px; border-bottom: 1px solid rgba(212,175,55,0.18); }
    .cover { width: 100%; aspect-ratio: 16/8; border-radius: 14px; overflow: hidden; margin: 36px 0; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
    .cover img { width: 100%; height: 100%; object-fit: cover; }
    .post-body { max-width: 740px; margin: 0 auto; padding: 0 32px 100px; font-size: 17px; color: rgba(255,255,255,0.85); line-height: 1.75; }
    .post-body p { margin-bottom: 22px; }
    .post-body h2 { font-family: 'Space Grotesk',sans-serif; text-transform: uppercase; font-size: 24px; letter-spacing: 0.5px; color: var(--white); margin: 36px 0 18px; }
    .post-body h3 { font-family: 'Space Grotesk',sans-serif; text-transform: uppercase; font-size: 17px; letter-spacing: 1px; color: var(--primary-gold); margin: 28px 0 10px; }
    .post-body blockquote { border-left: 3px solid var(--primary-gold); padding: 10px 22px; margin: 26px 0; font-style: italic; background: rgba(212,175,55,0.06); border-radius: 4px; }
    .post-body ul { margin: 16px 0 22px 26px; }
    .post-body li { margin-bottom: 8px; }
    .post-cta { max-width: 740px; margin: 0 auto; padding: 0 32px 90px; }
    .post-cta-inner { background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(30,65,112,0.4)); border: 1px solid rgba(212,175,55,0.25); border-radius: 16px; padding: 34px 32px; }
    .post-cta h2 { font-family:'Space Grotesk',sans-serif; text-transform:uppercase; font-size:22px; letter-spacing:0.5px; margin:8px 0 14px; }
    .post-cta p { color: rgba(255,255,255,0.8); font-size:15px; line-height:1.7; margin:0; }
    .post-cta a { color: var(--primary-gold); font-weight:600; }
    @media (max-width: 720px) { .post-hero, .post-body { padding-left: 22px; padding-right: 22px; } .post-hero { padding-top: 130px; } }
  </style>
</head>
<body>
  <SiteNav lang="hy" pathInLang={`/hy/blog/${post.slug}/`} />

  <article>
    <header class="post-hero">
      <div class="post-tag">{post.tag}</div>
      <h1>{post.title}</h1>
      <div class="meta">{new Date(post.publishedAt).toLocaleDateString('en-GB', {day:'numeric',month:'long',year:'numeric'})}</div>
      <div class="cover"><img src={post.cover} alt={post.title} /></div>
    </header>
    <div class="post-body" set:html={bodyHtml}></div>
  </article>

  <section class="post-cta">
    <div class="post-cta-inner">
      <div class="post-tag">Աշխատեք մեզ հետ</div>
      <h2>Ընտրված ղեկավար որոնում՝ փորձառու խորհրդատուի ղեկավարությամբ:</h2>
      <p>ArgusRecruit-ը վարում է գաղտնի <a href="/hy/services/">ղեկավար որոնում և headhunting</a> գործատուների համար Մեծ Բրիտանիայում, ԱՄԷ-ում, Կանադայում և Հայաստանում: Դիտարկո՞ւմ եք նոր դեր: <a href="/hy/jobs/">Դիտեք բաց դերերը</a>:</p>
    </div>
  </section>

  <footer>© 2026 ArgusRecruit · <a href="/hy/">Back to home</a> · <a href="/hy/blog/">All posts</a> · <a href="/hy/services/" style="color:var(--primary-gold)">Ծառայություններ</a> · <a href="/privacy/" style="color:var(--primary-gold)">Privacy</a></footer>
</body>
</html>
