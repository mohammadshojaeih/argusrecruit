---
import SiteHead from '../../components/SiteHead.astro';
import SharedCSS from '../../components/SharedCSS.astro';
import SiteNav from '../../components/SiteNav.astro';

const industries = [
  { name: "Տեխնոլոգիա", icon: "\ud83d\udcbb", desc: "Ինժեներական ղեկավարություն:" },
  { name: "Մարքեթինգ և Աճ", icon: "\ud83d\udce3", desc: "CMO, աճ, բրենդ:" },
  { name: "Ֆինանսներ", icon: "\ud83d\udcca", desc: "CFO, controllers, treasury:" },
  { name: "Բանկային գործ", icon: "\ud83c\udfe6", desc: "Կոմերցիոն, ներդրումային:" },
  { name: "Ապահովագրություն", icon: "\ud83d\udee1\ufe0f", desc: "Անդերռայթինգ:" },
  { name: "FinTech", icon: "\ud83d\udcb3", desc: "Վճարումներ, վարկավորում:" },
  { name: "Առողջապահություն", icon: "\ud83c\udfe5", desc: "Կլինիկական ղեկավարություն:" },
  { name: "Էներգետիկա", icon: "\u26a1", desc: "Նավթ, գազ, վերականգնվող:" },
  { name: "Անշարժ գույք", icon: "\ud83c\udfe2", desc: "Շինարարություն, PropTech:" },
  { name: "Արտադրություն", icon: "\u2699\ufe0f", desc: "Գործառնություններ, supply chain:" },
  { name: "Մանրածախ և E-commerce", icon: "\ud83d\uded2", desc: "Մերչանդայզինգ:" },
  { name: "Իրավաբանական", icon: "\u2696\ufe0f", desc: "GC, regulation, compliance:" }
]

const faqs = [
  { q: "Որքա՞ն է տևում որոնումը:", a: "Կարճ ցուցակ 7 օրում: Մինչև առաջարկ 6-10 շաբաթ:" },
  { q: "Ինչո՞վ եք տարբերվում:", a: "Պահպանվող (retained) պայմանագիր, ավագ ղեկավարությամբ:" },
  { q: "Ինչպե՞ս եք պաշտպանում գաղտնիությունը:", a: "Գաղտնիության արձանագրությամբ:" },
  { q: "Իսկ եթե նշանակումը չաշխատի:", a: "Նորից կորոնենք առանց վճարման:" },
  { q: "Միջազգային աշխատում եք:", a: "Այո: UK, UAE, Կանադա, Հայաստան:" }
]
---
<!DOCTYPE html>
<html lang="hy">
<head>
  <SiteHead title="Ծառայություններ — ArgusRecruit" description="Ղեկավար որոնում, headhunting և հավաքագրման ծառայություններ:" lang="hy" />
  <SharedCSS />
  <style is:global>
    body { background: var(--navy); }
    .svc-container { max-width: 1240px; margin: 0 auto; padding: 0 32px; }

    .svc-section { padding: 90px 32px; }
    .svc-section.alt { background: var(--navy-darkest); }
    .svc-section-header { text-align: center; max-width: 760px; margin: 0 auto 50px; }
    .svc-section-header .eyebrow { margin-bottom: 16px; }
    .svc-section-header h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 3.6vw, 42px); font-weight: 600; letter-spacing: 1px; line-height: 1.2; text-transform: uppercase; }
    .svc-section-header h2 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-section-header p { color: rgba(255,255,255,0.7); margin-top: 14px; font-size: 15px; line-height: 1.7; }

    .eyebrow { display: inline-flex; align-items: center; gap: 10px; font-size: 10px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; padding: 7px 18px; border: 1px solid rgba(212,175,55,0.35); border-radius: 999px; background: rgba(212,175,55,0.04); }
    .eyebrow::before, .eyebrow::after { content: ''; width: 4px; height: 4px; border-radius: 50%; background: var(--primary-gold); flex: 0 0 4px; }

    .svc-hero { padding: 160px 32px 90px; position: relative; overflow: hidden; background: linear-gradient(180deg, rgba(30,65,112,0.55) 0%, rgba(42,85,137,0.7) 100%), url('/svc-hero-bg.jpg') center/cover no-repeat; }
    .svc-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 0%, var(--navy) 100%); opacity: 0.5; pointer-events: none; }
    .svc-hero-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }
    .svc-hero .eyebrow { margin-bottom: 24px; }
    .svc-hero h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(36px, 5.5vw, 60px); font-weight: 600; line-height: 1.1; letter-spacing: 1.2px; text-transform: uppercase; max-width: 920px; margin-bottom: 22px; }
    .svc-hero h1 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-hero p { color: rgba(255,255,255,0.85); font-size: 18px; line-height: 1.65; max-width: 680px; margin-bottom: 34px; }
    .svc-cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

    .svc-metrics { background: var(--navy-deep); padding: 56px 32px; border-bottom: 1px solid rgba(212,175,55,0.12); }
    .svc-metrics-inner { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .svc-metric { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 14px; padding: 22px 24px; display: flex; align-items: center; gap: 16px; transition: all 0.25s; }
    .svc-metric:hover { border-color: rgba(212,175,55,0.45); background: rgba(255,255,255,0.06); transform: translateY(-2px); }
    .svc-metric-icon { width: 46px; height: 46px; border-radius: 12px; background: rgba(212,175,55,0.12); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); flex: 0 0 46px; }
    .svc-metric-icon svg { width: 22px; height: 22px; }
    .svc-metric-text .num { font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 2.4vw, 30px); font-weight: 700; color: var(--primary-gold); line-height: 1; margin-bottom: 4px; }
    .svc-metric-text .label { color: rgba(255,255,255,0.75); font-size: 13px; line-height: 1.4; }

    .svc-services { padding: 90px 32px; background: var(--navy); }
    .svc-operations { padding: 90px 32px; background: linear-gradient(180deg, #08182b 0%, var(--navy) 100%); }
    .svc-operations-inner { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr); gap: 50px; align-items: start; }
    .svc-operations-content { min-width: 0; }
    .svc-operations-content .eyebrow { margin-bottom: 18px; }
    .svc-operations-content h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 2.8vw, 34px); font-weight: 600; line-height: 1.2; letter-spacing: 1.5px; text-transform: uppercase; color: var(--white); }
    .svc-operations-content h2 .accent { color: var(--primary-gold); }
    .svc-operations-photo { position: sticky; top: 110px; border-radius: 16px; overflow: hidden; aspect-ratio: 4/5; border: 1px solid rgba(212,175,55,0.2); box-shadow: 0 30px 60px rgba(0,0,0,0.4); }
    .svc-operations-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .svc-operations-photo .badge { position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(14,36,64,0.85); border: 1px solid rgba(212,175,55,0.3); border-radius: 10px; padding: 14px 18px; display: flex; align-items: center; gap: 12px; }
    .svc-operations-photo .badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary-gold); }
    .svc-operations-photo .badge .text { color: var(--white); font-size: 13px; font-weight: 500; }
    .svc-operations-photo .badge .text span { color: var(--primary-gold); font-weight: 600; }
    .svc-services-layout { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr); gap: 50px; align-items: start; }
    .svc-photo { position: sticky; top: 110px; border-radius: 16px; overflow: hidden; aspect-ratio: 4/5; border: 1px solid rgba(212,175,55,0.2); box-shadow: 0 30px 60px rgba(0,0,0,0.4); }
    .svc-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .svc-photo .badge { position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(14,36,64,0.85); border: 1px solid rgba(212,175,55,0.3); border-radius: 10px; padding: 14px 18px; display: flex; align-items: center; gap: 12px; }
    .svc-photo .badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary-gold); }
    .svc-photo .badge .text { color: var(--white); font-size: 13px; font-weight: 500; }
    .svc-photo .badge .text span { color: var(--primary-gold); font-weight: 600; }
    .svc-services-content { min-width: 0; }
    .svc-services-content .eyebrow { margin-bottom: 18px; }
    .svc-services-content h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 2.8vw, 34px); font-weight: 600; line-height: 1.2; letter-spacing: 1.5px; text-transform: uppercase; color: var(--white); }
    .svc-services-content h2 .accent { color: var(--primary-gold); }
    .svc-lede { margin-top: 14px; color: rgba(255,255,255,0.75); font-size: 15px; line-height: 1.7; }
    .svc-lede .accent { color: var(--primary-gold); font-weight: 600; }
    .svc-tiers { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }
    .svc-tier { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 12px; padding: 20px 22px; display: flex; gap: 16px; align-items: flex-start; transition: all 0.25s; }
    .svc-tier:hover { border-color: rgba(212,175,55,0.4); background: rgba(255,255,255,0.06); }
    .svc-tier-icon { flex: 0 0 44px; width: 44px; height: 44px; border-radius: 10px; background: linear-gradient(135deg, rgba(212,175,55,0.2), rgba(184,134,11,0.08)); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); }
    .svc-tier-icon svg { width: 22px; height: 22px; }
    .svc-tier h3 { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 600; color: var(--white); text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 6px; }
    
    .svc-features { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 28px; padding-top: 28px; border-top: 1px solid rgba(212,175,55,0.12); }
    .svc-feature { background: rgba(255,255,255,0.025); border: 1px solid rgba(212,175,55,0.12); border-radius: 10px; padding: 18px 20px; display: flex; align-items: center; gap: 14px; }
    .svc-feature-icon { flex: 0 0 36px; height: 36px; border-radius: 8px; background: rgba(212,175,55,0.12); color: var(--primary-gold); display: flex; align-items: center; justify-content: center; }
    .svc-feature-icon svg { width: 18px; height: 18px; }
    .svc-feature-text strong { display: block; font-size: 14px; color: var(--white); margin-bottom: 2px; }
    .svc-feature-text span { font-size: 12.5px; color: rgba(255,255,255,0.6); line-height: 1.5; }
    @media (max-width: 760px) { .svc-features { grid-template-columns: 1fr; } }

    .svc-tier p { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.55; margin: 0; }

    .svc-industries-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .svc-industry-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.15); border-radius: 12px; padding: 22px; transition: all 0.25s; }
    .svc-industry-card:hover { border-color: rgba(212,175,55,0.4); background: rgba(255,255,255,0.06); transform: translateY(-2px); }
    .svc-industry-card .icon { font-size: 28px; margin-bottom: 12px; line-height: 1; }
    .svc-industry-card h4 { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 600; margin-bottom: 6px; color: var(--white); text-transform: uppercase; letter-spacing: 1px; }
    .svc-industry-card p { color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.5; }

    .svc-clients { background: var(--navy-deep); padding: 70px 32px; border-top: 1px solid rgba(212,175,55,0.12); border-bottom: 1px solid rgba(212,175,55,0.12); }
    .svc-clients-inner { max-width: 1240px; margin: 0 auto; text-align: center; }
    .svc-clients h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 3vw, 36px); font-weight: 600; line-height: 1.2; letter-spacing: 1.2px; margin-top: 14px; text-transform: uppercase; }
    .svc-clients h2 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-clients-sub { color: rgba(255,255,255,0.7); margin-top: 14px; font-size: 15px; max-width: 580px; margin-left: auto; margin-right: auto; }
    .svc-clients-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .svc-client { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 12px; padding: 24px 18px; display: flex; flex-direction: column; align-items: center; gap: 12px; min-height: 150px; position: relative; }
    .svc-client-img { width: 90px; height: 70px; display: flex; align-items: center; justify-content: center; filter: blur(14px) grayscale(1); }
    .svc-client-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .svc-client .name { font-size: 13px; color: rgba(255,255,255,0.85); }
    .svc-client::after { content: 'ԳԱՂՏՆԻ'; position: absolute; bottom: 10px; left: 0; right: 0; text-align: center; font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 10px; color: var(--primary-gold); letter-spacing: 2.5px; pointer-events: none; }
    .svc-clients-footer { margin-top: 30px; color: rgba(255,255,255,0.55); font-size: 13px; font-style: italic; }

    .svc-why { padding: 90px 32px; background: var(--navy); }
    .svc-why-banner { position: relative; border-radius: 16px; overflow: hidden; margin-bottom: 40px; aspect-ratio: 16/6; border: 1px solid rgba(212,175,55,0.2); }
    .svc-why-banner img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .svc-why-banner-overlay { position: absolute; inset: 0; display: flex; align-items: flex-end; padding: 32px 40px; background: linear-gradient(135deg, rgba(14,36,64,0.4) 0%, rgba(14,36,64,0.15) 50%, rgba(14,36,64,0.7) 100%); }
    .svc-why-banner-content { max-width: 560px; background: rgba(14,36,64,0.88); border: 1px solid rgba(212,175,55,0.25); border-radius: 12px; padding: 22px 26px; }
    .svc-why-banner-label { display: inline-block; font-size: 10px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; margin-bottom: 8px; }
    .svc-why-banner-text { font-family: 'Space Grotesk', sans-serif; font-size: clamp(15px, 1.7vw, 19px); font-weight: 500; line-height: 1.5; color: var(--white); }
    .svc-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .svc-why-card { background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0.005)); border: 1px solid rgba(212,175,55,0.12); border-radius: 14px; padding: 32px 28px; transition: all 0.3s; }
    .svc-why-card:hover { border-color: rgba(212,175,55,0.35); transform: translateY(-4px); }
    .svc-why-card .icon { width: 52px; height: 52px; border-radius: 12px; background: linear-gradient(135deg, rgba(212,175,55,0.18), rgba(184,134,11,0.08)); display: flex; align-items: center; justify-content: center; margin-bottom: 22px; color: var(--primary-gold); }
    .svc-why-card .icon svg { width: 26px; height: 26px; }
    .svc-why-card h3 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 600; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1.2px; }
    .svc-why-card p { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.65; }

    .svc-global { background: var(--navy-deep); padding: 90px 32px; border-top: 1px solid rgba(212,175,55,0.12); border-bottom: 1px solid rgba(212,175,55,0.12); }
    .svc-global-grid { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; }
    .svc-global-text h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 3.4vw, 40px); font-weight: 600; line-height: 1.15; letter-spacing: 1.2px; text-transform: uppercase; }
    .svc-global-text h2 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-global-text p { margin-top: 18px; color: rgba(255,255,255,0.7); font-size: 16px; line-height: 1.7; }
    .svc-country-list { display: grid; gap: 12px; margin-top: 28px; }
    .svc-country-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.15); border-radius: 10px; }
    .svc-country-item .flag { font-size: 22px; line-height: 1; }
    .svc-country-item .info { flex: 1; }
    .svc-country-item .info strong { display: block; font-size: 14px; font-weight: 600; color: var(--white); letter-spacing: 0.3px; }
    .svc-country-item .info span { font-size: 12px; color: rgba(255,255,255,0.55); }
    .svc-country-item .pulse { width: 10px; height: 10px; border-radius: 50%; background: var(--primary-gold); box-shadow: 0 0 0 0 rgba(212,175,55,0.7); animation: pulse 2.5s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(212,175,55,0.7); } 70% { box-shadow: 0 0 0 12px rgba(212,175,55,0); } 100% { box-shadow: 0 0 0 0 rgba(212,175,55,0); } }
    .svc-map-wrap { position: relative; border-radius: 14px; overflow: hidden; background: linear-gradient(135deg, rgba(212,175,55,0.05) 0%, rgba(14,36,64,0.3) 70%); padding: 24px; border: 1px solid rgba(212,175,55,0.18); }
    .svc-map-wrap object { width: 100%; height: auto; display: block; aspect-ratio: 950 / 360; min-height: 220px; }
    .svc-map-legend { display: flex; gap: 16px; align-items: center; margin-top: 16px; font-size: 11px; letter-spacing: 1.5px; color: rgba(255,255,255,0.6); text-transform: uppercase; }
    .svc-map-legend .ldot { width: 10px; height: 10px; border-radius: 2px; background: var(--primary-gold); display: inline-block; margin-right: 6px; vertical-align: middle; }
    .svc-map-legend .ldot.dim { background: #1B3B6F; }

    .svc-quote { padding: 90px 32px; position: relative; background: linear-gradient(180deg, rgba(8,30,62,0.78), rgba(14,36,64,0.88)), url('/cover.png') center/cover no-repeat; }
    .svc-quote-inner { max-width: 880px; margin: 0 auto; text-align: center; }
    .svc-quote-mark { font-family: 'Space Grotesk', serif; font-size: 120px; color: var(--primary-gold); opacity: 0.4; line-height: 1; margin-bottom: -30px; }
    .svc-quote blockquote { font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 2.8vw, 32px); font-weight: 400; line-height: 1.4; color: var(--white); font-style: italic; margin: 0 0 24px; }
    .svc-quote-attrib { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--primary-gold); font-weight: 600; }

    .svc-process { background: var(--navy); padding: 90px 32px; }
    .svc-process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; max-width: 1240px; margin: 0 auto; }
    .svc-process-step { background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0.005)); border: 1px solid rgba(212,175,55,0.12); border-radius: 14px; padding: 32px 26px; }
    .svc-process-step .num { font-family: 'Space Grotesk', sans-serif; font-size: 38px; font-weight: 600; color: var(--primary-gold); line-height: 1; opacity: 0.4; }
    .svc-process-step h4 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 600; margin-top: 10px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1.5px; }
    .svc-process-step p { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.6; }

    .svc-faq { padding: 90px 32px; background: var(--navy-deep); border-top: 1px solid rgba(212,175,55,0.12); border-bottom: 1px solid rgba(212,175,55,0.12); }
    .svc-faq-wrap { max-width: 820px; margin: 0 auto; }
    .svc-faq-item { border-bottom: 1px solid rgba(212,175,55,0.15); padding: 22px 0; cursor: pointer; }
    .svc-faq-item summary { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; color: var(--white); display: flex; justify-content: space-between; align-items: center; gap: 20px; list-style: none; }
    .svc-faq-item summary::-webkit-details-marker { display: none; }
    .svc-faq-item summary::after { content: '+'; color: var(--primary-gold); font-size: 24px; font-weight: 300; transition: transform 0.3s; }
    .svc-faq-item[open] summary::after { transform: rotate(45deg); }
    .svc-faq-item p { color: rgba(255,255,255,0.72); font-size: 15px; line-height: 1.75; margin-top: 14px; }

    .svc-contact { padding: 90px 32px; background: var(--navy); }
    .svc-contact-grid { max-width: 1240px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: 40px; align-items: start; }
    .svc-contact-info { display: flex; flex-direction: column; gap: 14px; }
    .svc-contact-item { display: flex; gap: 16px; align-items: center; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 12px; color: var(--white); transition: all 0.2s; text-decoration: none; }
    .svc-contact-item:hover { border-color: rgba(212,175,55,0.4); background: rgba(255,255,255,0.06); }
    .svc-contact-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(212,175,55,0.12); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); flex: 0 0 40px; }
    .svc-contact-icon svg { width: 20px; height: 20px; }
    .svc-contact-label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 4px; }
    .svc-form { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.25); border-radius: 16px; padding: 32px; }
    .svc-form h3 { font-family: 'Space Grotesk', sans-serif; font-size: 22px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 1px; }
    .svc-form-sub { color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 22px; }
    .svc-form-fields { display: grid; gap: 14px; }
    .svc-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .svc-form-group label { display: block; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-bottom: 6px; font-weight: 600; }
    .svc-form-group input, .svc-form-group select, .svc-form-group textarea { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(212,175,55,0.25); color: var(--white); padding: 11px 14px; border-radius: 8px; font-size: 14px; font-family: inherit; }
    .svc-form-group textarea { min-height: 110px; resize: vertical; }
    .svc-form-group input:focus, .svc-form-group select:focus, .svc-form-group textarea:focus { outline: none; border-color: var(--primary-gold); }

    
@media (max-width: 720px) {
  .svc-why-banner { aspect-ratio: auto !important; min-height: 360px; }
  .svc-why-banner img { position: absolute; inset: 0; object-fit: cover; }
  .svc-why-banner-overlay { position: relative !important; padding: 200px 14px 14px !important; background: linear-gradient(180deg, rgba(14,36,64,0) 0%, rgba(14,36,64,0.15) 50%, rgba(14,36,64,0.55) 100%) !important; }
  .svc-why-banner-content { max-width: 100% !important; padding: 14px 16px !important; background: rgba(14,36,64,0.72) !important; }
  .svc-why-banner-text { font-size: 14px !important; line-height: 1.5 !important; }
}

    
@media (max-width: 720px) { .svc-global-text .eyebrow { margin-bottom: 18px !important; display: inline-flex; } .svc-global-text h2 { margin-top: 0; } }
    
@media (max-width: 720px) { .svc-industry-card h4, .svc-industry-card p { overflow-wrap: anywhere; word-break: break-word; } .svc-industry-card h4 { font-size: 13px !important; letter-spacing: 0.5px !important; } .svc-industry-card p { font-size: 12px !important; } }
    @media (max-width: 960px) {
      .svc-metrics-inner, .svc-industries-grid, .svc-clients-grid { grid-template-columns: repeat(2, 1fr); }
      .svc-services-layout, .svc-operations-inner, .svc-global-grid, .svc-contact-grid { grid-template-columns: 1fr; gap: 32px; }
      .svc-photo, .svc-operations-photo { position: relative; aspect-ratio: 16/9; max-height: 380px; top: auto; }
      .svc-photo { position: relative; aspect-ratio: 16/9; max-height: 380px; top: auto; }
      .svc-why-grid, .svc-process-grid { grid-template-columns: 1fr 1fr; }
      .svc-why-banner { aspect-ratio: 16/9; }
      .svc-form-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .svc-hero { padding: 130px 20px 70px; }
      .svc-section, .svc-services, .svc-operations, .svc-clients, .svc-why, .svc-global, .svc-quote, .svc-process, .svc-faq, .svc-contact, .svc-metrics { padding-left: 20px; padding-right: 20px; }
      .svc-metrics-inner, .svc-why-grid, .svc-process-grid { grid-template-columns: 1fr; } .svc-clients-grid { grid-template-columns: minmax(0,1fr) minmax(0,1fr) !important; gap: 12px !important; } .svc-client { min-width: 0; padding: 18px 12px !important; min-height: 130px; } .svc-industries-grid { grid-template-columns: minmax(0,1fr) minmax(0,1fr) !important; gap: 10px; } .svc-industry-card { min-width: 0; padding: 18px 14px !important; }
      .svc-why-banner-overlay { padding: 18px; }
    }
  </style>
</head>
<body>
  <SiteNav lang="hy" pathInLang="/hy/services/" />

  <section class="svc-hero">
    <div class="svc-hero-inner">
      <span class="eyebrow">Գործատուների համար</span>
      <h1>Վարձեք առաջնորդներ, <span class="accent">ովքեր ձևավորում են</span> ձեր հաջորդ գլուխը.</h1>
      <p>ArgusRecruit-ը բուտիկ executive search ընկերություն է:</p>
      <div class="svc-cta-row">
        <a href="#contact" class="btn btn-primary">Կապվել մեր խորհրդատուի հետ</a>
      </div>
    </div>
  </section>

  <section class="svc-metrics">
    <div class="svc-metrics-inner">
      <div class="svc-metric"><div class="svc-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><div class="svc-metric-text"><div class="num">86%</div><div class="label">Հաջող նշանակումներ</div></div></div>
      <div class="svc-metric"><div class="svc-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="svc-metric-text"><div class="num">20 օր</div><div class="label">Վարձման միջին ժամանակ</div></div></div>
      <div class="svc-metric"><div class="svc-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12l4 6-10 13L2 9z"/></svg></div><div class="svc-metric-text"><div class="num">10,000+</div><div class="label">Մասնագետներ ցանցում</div></div></div>
      <div class="svc-metric"><div class="svc-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div><div class="svc-metric-text"><div class="num">4+</div><div class="label">Երկրներ որտեղ ենք գործում</div></div></div>
    </div>
  </section>

  <section class="svc-services">
    <div class="svc-services-layout">
      <div class="svc-photo">
        <img src="/photo-handshake.jpg" alt="ArgusRecruit consultation">
        <div class="badge"><span class="dot"></span><div class="text"><span>Վստահում են առաջնորդները</span> ողջ աշխարհում</div></div>
      </div>
      <div class="svc-services-content">
        <span class="eyebrow">Որոնման ծառայություններ</span>
        <h2>Շատ աչքեր, մեկ խոստում — <span class="accent">ճիշտ նշանակումը.</span></h2>
        <p class="svc-lede"><span class="accent">Ճիշտ նշանակումը</span> չի գտնվում ռեզյումեների կույտի մեջ:</p>
        <div class="svc-tiers">
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg></div>
            <div><h3>Ղեկավար Որոնում</h3><p>Ղեկավար (C-suite), Փոխնախագահ և բաժնի ղեկավարների դերերի համար:</p></div>
          </div>
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg></div>
            <div><h3>Հեդհանթինգ</h3><p>Դժվար գտնվող մասնագետների համար:</p></div>
          </div>
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            <div><h3>Հավաքագրման ծառայություններ</h3><p>Կառուցվածքային ամբողջական վարձում միջին և ավագ դերերի համար:</p></div>
          </div>
        </div>
        <div class="svc-features">
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L4 7v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V7l-8-5z"/></svg></div><div class="svc-feature-text"><strong>Լիարժեք գաղտնիություն</strong><span>Յուրաքանչյուր որոնում վարվում է գաղտնիությամբ:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 5l2 5h5l-4 3 1.5 5L12 15l-4.5 3L9 13l-4-3h5z"/></svg></div><div class="svc-feature-text"><strong>Որակ, ոչ քանակ</strong><span>Մեծ մասամբ նշանակումներ երեքից հինգ զրույցի ընթացքում:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="svc-feature-text"><strong>Փոխարինման երաշխիք</strong><span>Եթե նշանակումը չաշխատի, նորից կորոնենք:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/></svg></div><div class="svc-feature-text"><strong>Ավագ ռեկրուտեր, մեկ կապի կետ</strong><span>Անձամբ ղեկավարվում է ավագ ռեկրուտերի կողմից:</span></div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="svc-operations">
    <div class="svc-operations-inner">
      <div class="svc-operations-content">
        <span class="eyebrow">Տաղանդների գործառնություններ</span>
        <h2>Engineering Studio — <span class="accent">ձեր թիմը, կառուցված Երևանում.</span></h2>
        <p class="svc-lede">Երբ անհրաժեշտ է ոչ թե միայն մեկ նշանակում, այլ ամբողջ ինժեներական թիմ՝ արդեն աշխատանքի ընդունված, սարքավորված և գործող, մենք այն կառուցում և կառավարում ենք Երևանի մեր կենտրոնից: Դուք կառավարում եք աշխատանքը, իսկ մենք՝ մնացած ամեն ինչը:</p>
        <div class="svc-tiers svc-tiers-ops">
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M9 9h.01"/><path d="M9 12h.01"/><path d="M9 15h.01"/><path d="M9 18h.01"/></svg></div>
            <div><h3>Հավաքագրում</h3><p>Մենք գտնում, ընտրում և նշանակում ենք ինժեներների ձեր որակավորումներով և ընտրության գործընթացով: Միանգամյա նշանակման վճար:</p></div>
          </div>
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg></div>
            <div><h3>Հավաքագրում + Իրավաբանական գործատու (EOR)</h3><p>Մենք դառնում ենք իրավաբանական գործատու: Համապատասխան պայմանագրեր, աշխատավարձ, հարկեր, արտոնություններ՝ ամսական:</p></div>
          </div>
          <div class="svc-tier">
            <div class="svc-tier-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/></svg></div>
            <div><h3>Ամբողջական կառավարվող թիմ</h3><p>Հավաքագրում + աշխատանքի ընդունում + Երևանի գրասենյակ, IT, սարքավորում, HR: Միասնական թիմ մեկ վայրում:</p></div>
          </div>
        </div>
        <div class="svc-features">
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="svc-feature-text"><strong>60-70% ծախսերի խնայողություն</strong><span>Ավելի ցածր ծախսեր՝ Արևմտյան Եվրոպայում հավաքագրման համեմատ:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div class="svc-feature-text"><strong>Բրիֆից մինչև աշխատող թիմ՝ 4 շաբաթից պակաս</strong><span>30-րոպեանոց բրիֆ երկուշաբթի օրը: Աշխատող թիմ նույն ամսում:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div><div class="svc-feature-text"><strong>Մեկ գործընկեր: Մեկ հաշիվ-ապրանքագիր:</strong><span>Որոնում, պայմանագրեր, աշխատավարձ, գրասենյակ, սարքավորում, HR՝ մեկ ամսական հաշվետվությունում:</span></div></div>
          <div class="svc-feature"><div class="svc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11l-3-3-3 3"/><path d="M19 8v11"/></svg></div><div class="svc-feature-text"><strong>Փոխարինման պաշտպանություն</strong><span>Անվճար փոխարինում առաջին 90 օրվա ընթացքում՝ ցանկացած պատճառով:</span></div></div>
        </div>
      </div>
      <div class="svc-operations-photo">
        <img src="/photo-engineering-studio.jpg" alt="ArgusRecruit Engineering Studio Երևանում">
        <div class="badge"><span class="dot"></span><div class="text"><span>Ինժեներական թիմեր</span> Երևանում</div></div>
      </div>
    </div>
  </section>

  <section class="svc-section alt">
    <div class="svc-container">
      <div class="svc-section-header">
        <span class="eyebrow">Արդյունաբերություններ</span>
        <h2>Ոլորտներ, որոնք <span class="accent">խորապես գիտենք.</span></h2>
        <p>Մեր ցանցը ընդգրկում է տասներկու ոլորտ:</p>
      </div>
      <div class="svc-industries-grid">
        {industries.map(i => (
          <div class="svc-industry-card">
            <div class="icon">{i.icon}</div>
            <h4>{i.name}</h4>
            <p>{i.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="svc-clients">
    <div class="svc-clients-inner">
      <span class="eyebrow">Մեր Հաճախորդները</span>
      <h2>Ընկերություններ, որոնք <span class="accent">վստահում են մեզ</span> իրենց ամենադժվար նշանակումները</h2>
      <p class="svc-clients-sub">Թիմերի ընտրանի:</p>
      <div class="svc-clients-grid">
        <div class="svc-client"><div class="svc-client-img"><img src="/client-huma.png" alt="Huma"></div></div>
        <div class="svc-client"><div class="svc-client-img"><img src="/client-qoostudio.jpg" alt="QOO Studio"></div></div>
        <div class="svc-client"><div class="svc-client-img" style="background:#1a1a2e"><img src="/client-alien.jpg" alt="Alien Intellect"></div></div>
        <div class="svc-client"><div class="svc-client-img"><img src="/client-ovou.png" alt="OVOU"></div></div>
      </div>
      <div class="svc-clients-footer">— և աճող ցանկ —</div>
    </div>
  </section>

  <section class="svc-why">
    <div class="svc-container">
      <div class="svc-section-header">
        <span class="eyebrow">Ինչու ArgusRecruit</span>
        <h2>Որոնման գործընկեր, ով ձեր <span class="accent">հաջորդ քայլը</span> լուրջ է վերաբերվում.</h2>
        <p>Մենք համատեղում ենք մարդկային փորձառությունը:</p>
      </div>
      <div class="svc-why-banner">
        <img src="/photo-meeting.jpg" alt="ArgusRecruit team consultation">
        <div class="svc-why-banner-overlay">
          <div class="svc-why-banner-content">
            <div class="svc-why-banner-label">Ցանց և Շուկայի Խորություն</div>
            <div class="svc-why-banner-text">Հարաբերությունների տարիները տվել են ուղիղ մուտք:</div>
          </div>
        </div>
      </div>
      <div class="svc-why-grid">
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg></div>
          <h3>Շատ Աչքեր</h3>
          <p>Մի քանի ավագ ռեկրուտեր ամեն որոնման վրա:</p>
        </div>
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L4 7v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V7l-8-5z"/></svg></div>
          <h3>Լիարժեք Գաղտնիություն</h3>
          <p>Գաղտնիությունը չքննարկվող է:</p>
        </div>
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>Ճշգրիտ Համապատասխանություն</h3>
          <p>Մենք ուղարկում ենք ճիշտ մարդկանց:</p>
        </div>
      </div>
    </div>
  </section>

  <section class="svc-quote">
    <div class="svc-quote-inner">
      <div class="svc-quote-mark">"</div>
      <blockquote>Մեծ ընկերությունները հազվադեպ են կառուցվում միջին նշանակումներով:</blockquote>
      <div class="svc-quote-attrib">— ArgusRecruit-ի թիմը</div>
    </div>
  </section>

  <section class="svc-global">
    <div class="svc-global-grid">
      <div class="svc-global-text">
        <span class="eyebrow">Համաշխարհային Հասանելիություն</span>
        <h2>Հայաստանում տեղակայված. <span class="accent">Աշխատում ենք ամբողջ աշխարհում.</span></h2>
        <p>Մեր աշխատանքը գլոբալ է:</p>
        <div class="svc-country-list">
          <div class="svc-country-item"><span class="flag">🇬🇧</span><div class="info"><strong>Միացյալ Թագավորություն</strong><span>Լոնդոն · Ակտիվ հաճախորդներ</span></div><span class="pulse"></span></div>
          <div class="svc-country-item"><span class="flag">🇨🇦</span><div class="info"><strong>Կանադա</strong><span>Տորոնտո · Ակտիվ հաճախորդներ</span></div><span class="pulse"></span></div>
          <div class="svc-country-item"><span class="flag">🇦🇪</span><div class="info"><strong>ԱՄԷ</strong><span>Դուբայ · Ակտիվ հաճախորդներ</span></div><span class="pulse"></span></div>
          <div class="svc-country-item"><span class="flag">🇦🇲</span><div class="info"><strong>Հայաստան</strong><span>Երևան · Գլխավոր գրասենյակ</span></div><span class="pulse"></span></div>
        </div>
      </div>
      <div>
        <div class="svc-map-wrap"><object type="image/svg+xml" data="/world-map.svg" aria-label="World map highlighting countries we serve"></object></div>
        <div class="svc-map-legend"><span><span class="ldot"></span>Ակտիվ հաճախորդներ</span><span><span class="ldot dim"></span>Հասանելի տարածք</span></div>
      </div>
    </div>
  </section>

  <section class="svc-process">
    <div class="svc-container">
      <div class="svc-section-header">
        <span class="eyebrow">Ինչպես ենք աշխատում</span>
        <h2>Բրիֆից մինչև <span class="accent">առաջարկ.</span></h2>
        <p>Հստակ, կրկնվող գործընթաց:</p>
      </div>
      <div class="svc-process-grid">
        <div class="svc-process-step"><div class="num">01</div><h4>Բացահայտում</h4><p>Խորը ուսումնասիրություն:</p></div>
        <div class="svc-process-step"><div class="num">02</div><h4>Քարտեզագրում</h4><p>Շուկայի հետազոտություն:</p></div>
        <div class="svc-process-step"><div class="num">03</div><h4>Կարճ ցուցակ</h4><p>3–5 ստուգված թեկնածուներ:</p></div>
        <div class="svc-process-step"><div class="num">04</div><h4>Փակում</h4><p>Հարցազրույցների կազմակերպում:</p></div>
      </div>
    </div>
  </section>

  <section class="svc-faq">
    <div class="svc-container">
      <div class="svc-section-header">
        <span class="eyebrow">Հաճախակի հարցեր</span>
      </div>
      <div class="svc-faq-wrap">
        {faqs.map((f, i) => (
          <details class="svc-faq-item" open={i===0}>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="svc-contact" id="contact">
    <div class="svc-container">
      <div class="svc-section-header">
        <span class="eyebrow">Կապվեք մեզ հետ</span>
        <h2>Եկեք գտնենք <span class="accent">ճիշտ մեկին.</span></h2>
        <p>Մենք ուրախ կլինենք լսել ձեզ:</p>
      </div>
      <div class="svc-contact-grid">
        <div class="svc-contact-info">
          <a href="mailto:contact@argusrecruit.com" class="svc-contact-item">
            <div class="svc-contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><div class="svc-contact-label">Էլ. փոստ</div><div>contact@argusrecruit.com</div></div>
          </a>
          <a href="tel:+37477026948" class="svc-contact-item">
            <div class="svc-contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><div class="svc-contact-label">Հեռախոս</div><div>+374 77 026 948</div></div>
          </a>
          <a href="https://www.linkedin.com/company/argusrecruit/about" target="_blank" rel="noopener" class="svc-contact-item">
            <div class="svc-contact-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg></div>
            <div><div class="svc-contact-label">LinkedIn</div><div>linkedin.com/company/argusrecruit</div></div>
          </a>
          <div class="svc-contact-item" style="cursor:default">
            <div class="svc-contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><div class="svc-contact-label">Տեղակայություն</div><div>Yerevan, Հայաստան</div></div>
          </div>
        </div>
        <form class="svc-form" action="/api/contact" method="POST" enctype="multipart/form-data">
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">
          <h3>Սկսել զրույց</h3>
          <p class="svc-form-sub">Պատմեք մեզ, թե ինչ եք փնտրում:</p>
          <div class="svc-form-fields">
            <div class="svc-form-row">
              <div class="svc-form-group"><label>Լրիվ անուն</label><input name="name" type="text" required></div>
              <div class="svc-form-group"><label>Էլ. փոստ</label><input name="email" type="email" required></div>
            </div>
            <div class="svc-form-row">
              <div class="svc-form-group"><label>Ընկերություն</label><input name="company" type="text"></div>
              <div class="svc-form-group"><label>Ես եմ...</label><select name="intent"><option value="Գործատու">Գործատու</option><option value="Թեկնածու">Թեկնածու</option><option value="Այլ">Այլ</option></select></div>
            </div>
            <div class="svc-form-group"><label>Ինչպե՞ս կարող ենք օգնել:</label><textarea name="message" placeholder="Պատմեք մեզ համառոտ:" required></textarea></div>
            <button class="btn btn-primary" type="submit">Ուղարկել հաղորդագրությունը</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <footer style="text-align: center; padding: 40px 20px; color: rgba(255,255,255,0.5); font-size: 13px; background: var(--navy-darkest);">© 2026 ArgusRecruit · <a style="color:var(--primary-gold)" href="/hy/">Վերադառնալ գլխավոր էջ</a> · <a href="/privacy/" style="color:var(--primary-gold)">Privacy</a></footer>
</body>
</html>
