        {faqs.map((f, i) => (
          <details class="faq-item" open={i===0}>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Get in Touch -->
  <section class="svc-section" id="contact" style="background: var(--navy);">
