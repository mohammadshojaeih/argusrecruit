---
import SiteHead from '../../components/SiteHead.astro';
import SharedCSS from '../../components/SharedCSS.astro';
import SiteNav from '../../components/SiteNav.astro';

const industries = [
  { name: "Технологии", icon: "\ud83d\udcbb", desc: "Инженерное руководство, продукт, платформа." },
  { name: "Маркетинг и Рост", icon: "\ud83d\udce3", desc: "CMO, рост, бренд, performance." },
  { name: "Финансы", icon: "\ud83d\udcca", desc: "CFO, контроллеры, FP&A, treasury." },
  { name: "Банковское дело", icon: "\ud83c\udfe6", desc: "Коммерческий, розничный, инвестиционный." },
  { name: "Страхование", icon: "\ud83d\udee1\ufe0f", desc: "Андеррайтинг, выплаты, актуарии." },
  { name: "FinTech", icon: "\ud83d\udcb3", desc: "Платежи, кредитование, инфра, комплаенс." },
  { name: "Здравоохранение", icon: "\ud83c\udfe5", desc: "Клиническое руководство, операции, life sciences." },
  { name: "Энергетика", icon: "\u26a1", desc: "Нефть и газ, возобновляемая, ЖКХ." },
  { name: "Недвижимость", icon: "\ud83c\udfe2", desc: "Девелопмент, asset management, PropTech." },
  { name: "Производство", icon: "\u2699\ufe0f", desc: "Операции, supply chain, заводы." },
  { name: "Ритейл и E-commerce", icon: "\ud83d\uded2", desc: "Мерчандайзинг, ops, digital." },
  { name: "Юриспруденция", icon: "\u2696\ufe0f", desc: "GC, регулирование, риски, комплаенс." }
]

const faqs = [
  { q: "Сколько обычно длится поиск?", a: "Для большинства executive поисков шорт-лист готов в течение 7 дней после утверждения брифа. Время до оффера обычно 6-10 недель." },
  { q: "Чем ArgusRecruit отличается от contingent рекрутера?", a: "Наши контракты retained и ведутся старшими. Мы работаем с малым числом мандатов одновременно и представляем только тех, за кого ручаемся лично." },
  { q: "Как вы обеспечиваете конфиденциальность?", a: "Каждый поиск ведётся по протоколу конфиденциальности. Мы никогда не раскрываем ваше имя без явного разрешения." },
  { q: "Что если найм не сработает?", a: "Каждое размещение защищено гарантийным периодом — мы заново проводим поиск без дополнительных оплат." },
  { q: "Вы работаете международно?", a: "Да. Активные клиенты в UK, ОАЭ, Канаде и Армении. Работаем на английском, русском и армянском." }
]
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <SiteHead title="Услуги — ArgusRecruit" description="Исполнительный поиск, хедхантинг и рекрутинговые услуги. Конфиденциально, под руководством старших, ориентировано на результат." lang="ru" />
  <SharedCSS />
  <style is:global>
    .eyebrow, .svc-section-header .eyebrow, .svc-hero .eyebrow, .jobs-hero .eyebrow {
      display: inline-flex !important; align-items: center; gap: 10px;
      font-size: 10px !important; letter-spacing: 4px;
      color: var(--primary-gold); text-transform: uppercase; font-weight: 600;
      padding: 7px 18px !important; border: 1px solid rgba(212,175,55,0.35) !important;
      border-radius: 999px !important; margin-bottom: 16px;
      background: rgba(212,175,55,0.04); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    }
    .eyebrow::before, .eyebrow::after,
    .svc-section-header .eyebrow::before, .svc-section-header .eyebrow::after,
    .svc-hero .eyebrow::before, .svc-hero .eyebrow::after,
    .jobs-hero .eyebrow::before, .jobs-hero .eyebrow::after {
      content: ''; width: 4px; height: 4px; border-radius: 50%;
      background: var(--primary-gold); flex: 0 0 4px;
    }

    body { background: var(--navy); }
    .svc-hero { padding: 160px 32px 90px; position: relative; overflow: hidden; background: linear-gradient(180deg, rgba(8,30,62,0.65) 0%, rgba(14,36,64,0.85) 100%), url('/slide-1.jpg') center/cover no-repeat; }
    .svc-hero::before { content: ''; position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; background: radial-gradient(circle, rgba(212,175,55,0.15), transparent 70%); pointer-events: none; }
    .svc-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 0%, var(--navy) 100%); opacity: 0.4; pointer-events: none; }
    .svc-hero-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }
    .svc-hero .eyebrow { display: inline-block; font-size: 11px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; padding: 7px 18px; border: 1px solid rgba(212,175,55,0.35); border-radius: 999px; margin-bottom: 28px; }
    .svc-hero h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(34px, 5vw, 56px); font-weight: 600; line-height: 1.15; letter-spacing: 1.5px; text-transform: uppercase; max-width: 880px; margin-bottom: 22px; }
    .svc-hero h1 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-hero p { color: rgba(255,255,255,0.75); font-size: 18px; line-height: 1.65; max-width: 680px; margin-bottom: 38px; }
    .svc-cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

    .svc-section { padding: 100px 32px; }
    .svc-section.alt { background: var(--navy-darkest); }
    .svc-section-inner { max-width: 1200px; margin: 0 auto; }
    .svc-section-header { text-align: center; max-width: 720px; margin: 0 auto 60px; }
    .svc-section-header .eyebrow { display: inline-block; font-size: 11px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; margin-bottom: 16px; }
    .svc-section-header h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 3vw, 38px); font-weight: 600; line-height: 1.2; letter-spacing: 2px; text-transform: uppercase; }
    .svc-section-header h2 .accent { color: var(--primary-gold); font-style: italic; }
    .svc-section-header p { color: rgba(255,255,255,0.7); font-size: 16px; line-height: 1.7; margin-top: 18px; }

    .tiers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .tier-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.2); border-radius: 16px; padding: 36px 32px; position: relative; transition: all 0.3s; }
    .tier-card:hover { border-color: rgba(212,175,55,0.5); transform: translateY(-4px); background: rgba(255,255,255,0.06); }
    .tier-card.flagship { border-color: rgba(212,175,55,0.5); background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(255,255,255,0.04)); }
    .tier-card .tier-badge { position: absolute; top: -10px; left: 28px; background: var(--primary-gold); color: var(--navy-darkest); font-size: 10px; font-weight: 700; letter-spacing: 1.5px; padding: 4px 10px; border-radius: 4px; }
    .tier-icon { width: 52px; height: 52px; border-radius: 12px; background: rgba(212,175,55,0.12); border: 1px solid rgba(212,175,55,0.3); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); margin-bottom: 22px; }
    .tier-icon svg { width: 24px; height: 24px; }
    .tier-card h3 { font-family: 'Space Grotesk', sans-serif; font-size: 19px; font-weight: 600; margin-bottom: 12px; letter-spacing: 1.5px; text-transform: uppercase; }
    .tier-card .tier-tagline { color: var(--primary-gold); font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; font-weight: 600; }
    .tier-card p { color: rgba(255,255,255,0.75); font-size: 14.5px; line-height: 1.7; margin-bottom: 20px; }
    .tier-card ul { padding: 0; list-style: none; }
    .tier-card li { color: rgba(255,255,255,0.7); font-size: 13.5px; padding: 6px 0 6px 22px; position: relative; line-height: 1.55; }
    .tier-card li::before { content: '✓'; position: absolute; left: 0; color: var(--primary-gold); font-weight: 700; }

    .industries-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .industry-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.15); border-radius: 12px; padding: 24px 22px; transition: all 0.25s; }
    .industry-card:hover { border-color: rgba(212,175,55,0.4); background: rgba(255,255,255,0.06); transform: translateY(-2px); }
    .industry-icon { font-size: 28px; margin-bottom: 12px; line-height: 1; }
    .industry-card h4 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 500; margin-bottom: 6px; color: var(--white); letter-spacing: 0.2px; }
    .industry-card p { color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.55; }

    .why-cards-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .svc-why-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 14px; padding: 32px 28px; }
    .svc-why-card .icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(212,175,55,0.12); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); margin-bottom: 18px; }
    .svc-why-card .icon svg { width: 22px; height: 22px; }
    .svc-why-card h3 { font-family: 'Space Grotesk', sans-serif; font-size: 19px; font-weight: 500; margin-bottom: 10px; }
    .svc-why-card p { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.7; }

    .process-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
    .svc-process-step { position: relative; }
    .svc-process-step .num { font-family: 'Space Grotesk', sans-serif; font-size: 42px; font-weight: 500; color: var(--primary-gold); opacity: 0.4; line-height: 1; margin-bottom: 14px; }
    .svc-process-step h4 { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500; margin-bottom: 10px; }
    .svc-process-step p { color: rgba(255,255,255,0.65); font-size: 14px; line-height: 1.6; }

    .stats-svc { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; padding: 60px 0; border-top: 1px solid rgba(212,175,55,0.15); border-bottom: 1px solid rgba(212,175,55,0.15); }
    .stats-svc .stat-item { text-align: center; }
    .stats-svc .stat-num { font-family: 'Space Grotesk', sans-serif; font-size: clamp(32px, 4vw, 48px); color: var(--primary-gold); font-weight: 500; line-height: 1; }
    .stats-svc .stat-label { color: rgba(255,255,255,0.65); font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; margin-top: 12px; }

    .guarantees { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .guarantee-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(212,175,55,0.2); border-radius: 14px; padding: 28px 26px; }
    .guarantee-card .gicon { width: 44px; height: 44px; border-radius: 50%; background: var(--primary-gold); color: var(--navy-darkest); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 18px; margin-bottom: 18px; }
    .guarantee-card h4 { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; margin-bottom: 8px; }
    .guarantee-card p { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.65; }

    .faq-wrap { max-width: 820px; margin: 0 auto; }
    .faq-item { border-bottom: 1px solid rgba(212,175,55,0.15); padding: 22px 0; cursor: pointer; }
    .faq-item summary { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; color: var(--white); display: flex; justify-content: space-between; align-items: center; list-style: none; gap: 20px; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; color: var(--primary-gold); font-size: 24px; font-weight: 300; transition: transform 0.3s; }
    .faq-item[open] summary::after { transform: rotate(45deg); }
    .faq-item p { color: rgba(255,255,255,0.72); font-size: 15px; line-height: 1.75; margin-top: 14px; }

    .final-cta { background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(14,36,64,0.6)); border: 1px solid rgba(212,175,55,0.3); border-radius: 20px; padding: 60px 50px; text-align: center; }
    .final-cta h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(28px, 3.5vw, 38px); font-weight: 500; margin-bottom: 16px; letter-spacing: -0.3px; }
    .final-cta h2 .accent { color: var(--primary-gold); font-style: italic; }
    .final-cta p { color: rgba(255,255,255,0.75); font-size: 16px; max-width: 580px; margin: 0 auto 30px; line-height: 1.7; }

    
    .svc-quote-section { padding: 80px 32px; }
    .svc-quote { max-width: 880px; margin: 0 auto; text-align: center; position: relative; }
    .svc-quote .quote-mark { font-family: 'Space Grotesk', serif; font-size: 120px; color: var(--primary-gold); opacity: 0.4; line-height: 1; margin-bottom: -30px; }
    .svc-quote blockquote { font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 2.8vw, 32px); font-weight: 400; line-height: 1.4; color: var(--white); font-style: italic; margin-bottom: 24px; }
    .svc-quote .quote-attrib { font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: var(--primary-gold); font-weight: 600; }

    .svc-contact-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 40px; align-items: start; }
    .svc-contact-info { display: flex; flex-direction: column; gap: 14px; }
    .svc-contact-item { display: flex; gap: 16px; align-items: center; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 12px; color: var(--white); transition: all 0.2s; text-decoration: none; }
    .svc-contact-item:hover { border-color: rgba(212,175,55,0.4); background: rgba(255,255,255,0.06); }
    .svc-cicon { width: 40px; height: 40px; border-radius: 10px; background: rgba(212,175,55,0.12); display: flex; align-items: center; justify-content: center; color: var(--primary-gold); flex: 0 0 40px; }
    .svc-cicon svg { width: 20px; height: 20px; }
    .svc-clabel { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 4px; }
    .svc-form { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.25); border-radius: 16px; padding: 32px; }
    .svc-form h3 { font-family: 'Space Grotesk', sans-serif; font-size: 22px; margin-bottom: 6px; }
    .svc-form-subtitle { color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 22px; }
    .svc-form-fields { display: grid; gap: 14px; }
    .svc-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .svc-form-group label { display: block; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-bottom: 6px; font-weight: 600; }
    .svc-form-group input, .svc-form-group select, .svc-form-group textarea { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(212,175,55,0.25); color: var(--white); padding: 11px 14px; border-radius: 8px; font-size: 14px; font-family: inherit; }
    .svc-form-group textarea { min-height: 110px; resize: vertical; }
    .svc-form-group input:focus, .svc-form-group select:focus, .svc-form-group textarea:focus { outline: none; border-color: var(--primary-gold); }
    @media (max-width: 880px) { .svc-contact-grid { grid-template-columns: 1fr; } .svc-form-row { grid-template-columns: 1fr; } }

    @media (max-width: 960px) {
      .tiers-grid, .industries-grid, .why-cards-row, .process-row, .stats-svc, .guarantees { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .svc-hero { padding: 130px 20px 70px; }
      .svc-section { padding: 70px 20px; }
      .tiers-grid, .industries-grid, .why-cards-row, .process-row, .stats-svc, .guarantees { grid-template-columns: 1fr; }
      .final-cta { padding: 40px 24px; }
    }
  </style>
</head>
<body>
  <SiteNav lang="ru" pathInLang="/ru/services/" />

  <section class="svc-hero">
    <div class="svc-hero-inner">
      <span class="eyebrow">Для работодателей</span>
      <h1>Найдите лидеров, <span class="accent">которые формируют</span> вашу следующую главу.</h1>
      <p>ArgusRecruit — бутиковая фирма executive search для найма, который определит следующее десятилетие вашей компании. Конфиденциально. Под руководством старших.</p>
      <div class="svc-cta-row">
        <a href="/#contact" class="btn btn-primary">Связаться с нашим консультантом</a>
      </div>
    </div>
  </section>

  <!-- Service Tiers -->
  <section class="svc-section" id="tiers">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Наши услуги</span>
        <h2>Три формата. <span class="accent">Один стандарт.</span></h2>
        <p>От конфиденциальных C-suite поисков до структурированного найма — каждое сотрудничество ведётся лично старшим рекрутером.</p>
      </div>
      <div class="tiers-grid">
        <div class="tier-card flagship">
          <span class="tier-badge">FLAGSHIP</span>
          <div class="tier-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle fill="currentColor" cx="12" cy="12" r="2"/></svg>
          </div>
          <div class="tier-tagline">Executive Search</div>
          <h3>C-suite и Совет директоров</h3>
          <p>Для назначений CEO, C-suite, VP и Head-of-Function, где конфиденциальность и старшее суждение важнее всего.</p>
          <ul>
            <li>Ретейнерная модель</li>
            <li>Off-market и конфиденциальный outreach</li>
            <li>Старший рекрутер на каждом поиске</li>
            <li>Шорт-лист за 7 дней</li>
            <li>Гарантия замены</li>
          </ul>
        </div>
        <div class="tier-card">
          <div class="tier-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
          </div>
          <div class="tier-tagline">Хедхантинг</div>
          <h3>Трудно-находимые специалисты</h3>
          <p>Для технических и коммерческих специалистов, которые не ищут активно — и не на job boards.</p>
          <ul>
            <li>Активное картирование рынка</li>
            <li>Дискретный, персонализированный outreach</li>
            <li>Engineering, продукт, продажи, финансы</li>
            <li>Старший-led от старта до закрытия</li>
          </ul>
        </div>
        <div class="tier-card">
          <div class="tier-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="tier-tagline">Рекрутинговые услуги</div>
          <h3>Средне-старший найм</h3>
          <p>Структурированный end-to-end найм. Для быстрорастущих команд.</p>
          <ul>
            <li>Целевой sourcing и скрининг</li>
            <li>Структурированные оценки</li>
            <li>Объёмные, качество-первый</li>
            <li>Мульти-роль контракты</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Индустрии -->
  <section class="svc-section alt">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Индустрии</span>
        <h2>Сектора, которые <span class="accent">знаем глубоко.</span></h2>
        <p>Наша сеть и знание рынка охватывают двенадцать вертикалей — от FinTech до здравоохранения.</p>
      </div>
      <div class="industries-grid">
        {industries.map(i => (
          <div class="industry-card">
            <div class="industry-icon">{i.icon}</div>
            <h4>{i.name}</h4>
            <p>{i.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why -->
  <section class="svc-section">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Почему ArgusRecruit</span>
        <h2>Партнёр по поиску с <span class="accent">сетью и глубиной,</span> которых требует ваш поиск.</h2>
        <p>Годы построенных отношений дали нам прямой доступ к старшим талантам — и контекст рынка, чтобы знать, кто подходит, а не просто кто доступен.</p>
      </div>
      <div class="why-cards-row">
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg></div>
          <h3>Много Глаз</h3>
          <p>Несколько старших рекрутеров на каждом поиске. Покрытие как enterprise команда — без бюрократии.</p>
        </div>
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L4 7v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V7l-8-5z"/></svg></div>
          <h3>Полная Конфиденциальность</h3>
          <p>Конфиденциальность необсуждаема. Ваш поиск, кандидаты, timeline — защищены.</p>
        </div>
        <div class="svc-why-card">
          <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <h3>Точное Соответствие</h3>
          <p>Мы не отправляем резюме. Мы отправляем правильных людей — введённых в контекст вашей роли.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="svc-section svc-quote-section">
    <div class="svc-section-inner">
      <div class="svc-quote">
        <div class="quote-mark">"</div>
        <blockquote>Правильный найм не просто закрывает позицию — он перестраивает команду вокруг себя. Наша задача — найти того, чьё присутствие поднимает планку для всех в комнате.</blockquote>
        <div class="quote-attrib">— Команда ArgusRecruit</div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="svc-section alt">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Как мы работаем</span>
        <h2>От брифа до <span class="accent">офера.</span></h2>
        <p>Чёткий, повторяемый процесс, уважающий ваше время.</p>
      </div>
      <div class="process-row">
        <div class="svc-process-step">
          <div class="num">01</div>
          <h4>Знакомство</h4>
          <p>Глубокое погружение в роль и must-haves.</p>
        </div>
        <div class="svc-process-step">
          <div class="num">02</div>
          <h4>Картирование</h4>
          <p>Исследование рынка, longlist и дискретный outreach.</p>
        </div>
        <div class="svc-process-step">
          <div class="num">03</div>
          <h4>Шорт-лист</h4>
          <p>3–5 проверенных кандидатов со структурированными заметками — за 7 дней.</p>
        </div>
        <div class="svc-process-step">
          <div class="num">04</div>
          <h4>Закрытие</h4>
          <p>Координация интервью, поддержка офера и онбординга.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Глобальный охват -->
  <section class="svc-section">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Глобальный охват</span>
        <h2>Базируемся в Армении. <span class="accent">Работаем по всему миру.</span></h2>
        <p>Хотя Ереван — наш дом, наша работа глобальна.</p>
      </div>
      <div class="industries-grid">
        <div class="industry-card">
          <div class="industry-icon">🇬🇧</div>
          <h4>Великобритания</h4>
          <p>Лондон · Активные клиенты</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon">🇨🇦</div>
          <h4>Канада</h4>
          <p>Торонто · Активные клиенты</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon">🇦🇪</div>
          <h4>ОАЭ</h4>
          <p>Дубай · Активные клиенты</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon">🇦🇲</div>
          <h4>Армения</h4>
          <p>Ереван · Главный офис</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="svc-section">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">FAQ</span>
        <h2>Частые <span class="accent">вопросы.</span></h2>
      </div>
      <div class="faq-wrap">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i===0}>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Get in Touch -->
  <section class="svc-section alt" id="contact">
    <div class="svc-section-inner">
      <div class="svc-section-header">
        <span class="eyebrow">Связаться с нами</span>
        <h2>Найдём <span class="accent">того самого.</span></h2>
        <p>Нанимаете ключевую роль или думаете о следующем карьерном шаге — мы будем рады услышать вас. Все разговоры конфиденциальны.</p>
      </div>
      <div class="svc-contact-grid">
        <div class="svc-contact-info">
          <a href="mailto:contact@argusrecruit.com" class="svc-contact-item">
            <div class="svc-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><div class="svc-clabel">Email</div><div>contact@argusrecruit.com</div></div>
          </a>
          <a href="tel:+37477026948" class="svc-contact-item">
            <div class="svc-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><div class="svc-clabel">Телефон</div><div>+374 77 026 948</div></div>
          </a>
          <a href="https://www.linkedin.com/company/argusrecruit/about" target="_blank" rel="noopener" class="svc-contact-item">
            <div class="svc-cicon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg></div>
            <div><div class="svc-clabel">LinkedIn</div><div>linkedin.com/company/argusrecruit</div></div>
          </a>
          <div class="svc-contact-item" style="cursor:default;">
            <div class="svc-cicon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><div class="svc-clabel">Локация</div><div>Ереван, Армения</div></div>
          </div>
        </div>
        <form class="svc-form" action="/api/contact" method="POST" enctype="multipart/form-data">
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">
          <h3>Начнём разговор</h3>
          <p class="svc-form-subtitle">Расскажите, что вы ищете. Мы ответим в течение одного рабочего дня.</p>
          <div class="svc-form-fields">
            <div class="svc-form-row">
              <div class="svc-form-group">
                <label>Полное имя</label>
                <input name="name" type="text" required>
              </div>
              <div class="svc-form-group">
                <label>Email</label>
                <input name="email" type="email" required>
              </div>
            </div>
            <div class="svc-form-row">
              <div class="svc-form-group">
                <label>Компания</label>
                <input name="company" type="text">
              </div>
              <div class="svc-form-group">
                <label>Я...</label>
                <select name="intent">
                  <option value="Employer hiring talent">Работодатель, ищущий таланты</option>
                  <option value="Candidate exploring roles">Кандидат, рассматривающий вакансии</option>
                  <option value="Other">Другое</option>
                </select>
              </div>
            </div>
            <div class="svc-form-group">
              <label>Как мы можем помочь?</label>
              <textarea name="message" placeholder="Расскажите кратко о роли или своих целях..." required></textarea>
            </div>
            <button class="btn btn-primary" type="submit">Отправить сообщение →</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <footer style="text-align: center; padding: 40px 20px; color: rgba(255,255,255,0.5); font-size: 13px; background: var(--navy-darkest);">© 2026 ArgusRecruit · <a style="color:var(--primary-gold)" href="/ru/">Назад на главную</a></footer>
</body>
</html>
