<script>
// === Language switcher (dropdown only — actual language is determined by URL) ===
(function(){
  const sw = document.getElementById('langSwitcher');
  if (!sw) return;
  const cur = document.getElementById('langCurrent');
  // Detect current language from path
  const path = location.pathname;
  let lang = 'en';
  if (path.startsWith('/ru')) lang = 'ru';
  else if (path.startsWith('/hy')) lang = 'hy';
  if (cur) cur.textContent = {en:'🇬🇧', ru:'🇷🇺', hy:'🇦🇲'}[lang] || lang.toUpperCase();
  sw.querySelectorAll('.lang-menu a').forEach(a => a.classList.toggle('active', a.dataset.lang === lang));
  cur.addEventListener('click', (e) => { e.stopPropagation(); sw.classList.toggle('open'); });
  document.addEventListener('click', () => sw.classList.remove('open'));
})();

// Hero slideshow
(function(){
  const slides = document.querySelectorAll('.hero-slide');
  const captions = document.querySelectorAll('.hero-caption');
  const controls = document.getElementById('slideControls');
  if (!slides.length) return;
  let idx = 0; let timer;
  const dots = [];
  slides.forEach((_, i) => {
    const b = document.createElement('button');
    b.className = 'slide-dot' + (i === 0 ? ' active' : '');
    b.setAttribute('aria-label', 'Go to slide ' + (i+1));
    b.addEventListener('click', () => { go(i); reset(); });
    controls.appendChild(b);
    dots.push(b);
  });
  function go(n) {
    slides[idx].classList.remove('active');
    captions[idx].classList.remove('active');
    dots[idx].classList.remove('active');
    idx = (n + slides.length) % slides.length;
    slides[idx].classList.add('active');
    captions[idx].classList.add('active');
    dots[idx].classList.add('active');
  }
  function reset() { clearInterval(timer); timer = setInterval(() => go(idx + 1), 11000); }
  reset();

  document.getElementById('slidePrev')?.addEventListener('click', () => { go(idx - 1); reset(); });
  document.getElementById('slideNext')?.addEventListener('click', () => { go(idx + 1); reset(); });

  // Drag / swipe gestures
  const hero = document.querySelector('.hero');
  let startX = 0, startY = 0, dragging = false, moved = false;
  const THRESHOLD = 60;
  function onStart(e) {
    const t = e.touches ? e.touches[0] : e;
    startX = t.clientX; startY = t.clientY;
    dragging = true; moved = false;
    hero.style.cursor = 'grabbing';
  }
  function onMove(e) {
    if (!dragging) return;
    const t = e.touches ? e.touches[0] : e;
    const dx = t.clientX - startX;
    const dy = t.clientY - startY;
    if (Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy)) {
      moved = true;
      if (e.cancelable) e.preventDefault();
    }
  }
  function onEnd(e) {
    if (!dragging) return;
    dragging = false;
    hero.style.cursor = '';
    if (!moved) return;
    const t = e.changedTouches ? e.changedTouches[0] : e;
    const dx = t.clientX - startX;
    if (Math.abs(dx) > THRESHOLD) {
      if (dx < 0) go(idx + 1);
      else go(idx - 1);
      reset();
    }
  }
  hero.addEventListener('mousedown', onStart);
  hero.addEventListener('mousemove', onMove);
  hero.addEventListener('mouseup', onEnd);
  hero.addEventListener('mouseleave', onEnd);
  hero.addEventListener('touchstart', onStart, { passive: true });
  hero.addEventListener('touchmove', onMove, { passive: false });
  hero.addEventListener('touchend', onEnd, { passive: true });
  hero.style.cursor = 'grab';
  hero.style.touchAction = 'pan-y';

  // Keyboard support
  window.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') { go(idx - 1); reset(); }
    if (e.key === 'ArrowRight') { go(idx + 1); reset(); }
  });
})();

// Nav transparent on top
(function(){
  const nav = document.querySelector('.nav');
  const hero = document.querySelector('.hero');
  if (!nav || !hero) return;
  const onScroll = () => {
    if (window.scrollY < 60) nav.classList.add('transparent');
    else nav.classList.remove('transparent');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
})();

// Mobile menu toggle
document.getElementById('menuToggle').addEventListener('click', () => {
  document.getElementById('navLinks').classList.toggle('open');
});
document.querySelectorAll('#navLinks a').forEach(a => {
  a.addEventListener('click', () => document.getElementById('navLinks').classList.remove('open'));
});

// Scroll reveal
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.15 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// File input filename display
const fileInput = document.getElementById('attachment');
const fileText = document.getElementById('fileText');
if (fileInput) {
  fileInput.addEventListener('change', () => {
    const f = fileInput.files[0];
    if (f) {
      const mb = (f.size / (1024*1024)).toFixed(2);
      if (f.size > 10 * 1024 * 1024) {
        fileText.textContent = `⚠ ${f.name} (${mb} MB) — exceeds 10 MB limit`;
        fileText.classList.remove('has-file');
        fileInput.value = '';
      } else {
        fileText.textContent = `✓ ${f.name} (${mb} MB)`;
        fileText.classList.add('has-file');
      }
    } else {
      fileText.textContent = 'Click to attach a file (max 10 MB)';
      fileText.classList.remove('has-file');
    }
  });
}

// AJAX form submit via FormSubmit
const contactForm = document.getElementById('contactForm');
if (contactForm) {
  contactForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const success = document.getElementById('formSuccess');
    const error = document.getElementById('formError');
    success.style.display = 'none'; error.style.display = 'none';
    btn.disabled = true; btn.textContent = 'Sending...';
    try {
      const fd = new FormData(contactForm);
      const res = await fetch(contactForm.action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } });
      if (res.ok) {
        success.style.display = 'block';
        contactForm.querySelector('.form-fields').style.display = 'none';
      } else {
        error.style.display = 'block';
        btn.disabled = false; btn.textContent = 'Send Message →';
      }
    } catch (err) {
      error.style.display = 'block';
      btn.disabled = false; btn.textContent = 'Send Message →';
    }
  });
}
// Show success banner if redirected back with ?sent=1
if (new URLSearchParams(location.search).get('sent') === '1') {
  const s = document.getElementById('formSuccess');
  if (s) {
    s.style.display = 'block';
    const ff = document.querySelector('.form-fields');
    if (ff) ff.style.display = 'none';
    document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
  }
}
</script>

