---
import { getPosts } from '../../lib/sanity.js';
import SiteHead from '../../components/SiteHead.astro';
import SharedCSS from '../../components/SharedCSS.astro';
import SiteNav from '../../components/SiteNav.astro';

const posts = await getPosts('en');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SiteHead title="Blog — ArgusRecruit" description="Practical perspectives on executive search and leadership hiring." lang="en" />
  <SharedCSS />
  <style>
    .blog-hero { padding: 160px 32px 70px; background: linear-gradient(180deg, var(--navy-darkest), var(--navy)); text-align: center; border-bottom: 1px solid rgba(212,175,55,0.12); }
    .blog-hero .eyebrow { display: inline-block; font-size: 11px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; padding: 7px 18px; border: 1px solid rgba(212,175,55,0.35); border-radius: 999px; margin-bottom: 22px; }
    .blog-hero h1 { font-family: 'Space Grotesk',sans-serif; font-size: clamp(36px,5vw,56px); font-weight: 500; letter-spacing: -1px; text-transform: uppercase; line-height: 1.1; }
    .blog-hero h1 .accent { color: var(--primary-gold); }
    .blog-hero p { color: rgba(255,255,255,0.7); margin-top: 22px; font-size: 16px; max-width: 620px; margin-inline: auto; }
    .posts { max-width: 1240px; margin: 0 auto; padding: 70px 32px 90px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .post-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.15); border-radius: 14px; overflow: hidden; transition: all 0.3s; display: flex; flex-direction: column; }
    .post-card:hover { border-color: rgba(212,175,55,0.35); transform: translateY(-4px); }
    .post-img { aspect-ratio: 16/10; overflow: hidden; background: var(--navy-deep); }
    .post-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .post-card:hover .post-img img { transform: scale(1.05); }
    .post-body { padding: 22px 24px 26px; flex: 1; display: flex; flex-direction: column; }
    .post-tag { font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--primary-gold); font-weight: 600; margin-bottom: 10px; }
    .post-card h3 { font-family: 'Space Grotesk',sans-serif; font-size: 20px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; line-height: 1.25; margin-bottom: 12px; color: var(--white); }
    .post-excerpt { color: rgba(255,255,255,0.65); font-size: 14px; line-height: 1.6; flex: 1; }
    .post-meta { display: flex; justify-content: space-between; margin-top: 20px; padding-top: 16px; border-top: 1px solid rgba(212,175,55,0.12); font-size: 12px; color: rgba(255,255,255,0.55); }
    .read-more { color: var(--primary-gold); font-weight: 600; }
    .read-more::after { content: ' →'; }
    @media (max-width: 960px) { .posts { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .posts { grid-template-columns: 1fr; padding: 50px 20px 70px; } .blog-hero { padding: 140px 20px 60px; } }
  </style>
</head>
<body>
  <SiteNav lang="en" pathInLang="/blog/" />

  <section class="blog-hero">
    <span class="eyebrow">Insights</span>
    <h1>From the <span class="accent">ArgusRecruit</span> Journal</h1>
    <p>Practical perspectives on executive search, leadership hiring, and the modern workplace.</p>
  </section>

  <section class="posts">
    {posts.map(p => (
      <article class="post-card">
        <a href={`/blog/${p.slug}/`}>
          <div class="post-img"><img src={p.cover} alt="" /></div>
          <div class="post-body">
            <div class="post-tag">{p.tag}</div>
            <h3>{p.title}</h3>
            <p class="post-excerpt">{p.excerpt}</p>
            <div class="post-meta">
              <span>{new Date(p.publishedAt).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'})}</span>
              <span class="read-more">Read</span>
            </div>
          </div>
        </a>
      </article>
    ))}
  </section>

  <footer>© 2026 ArgusRecruit · <a href="/">Back to home</a></footer>
</body>
</html>
