---
import SiteHead from '../components/SiteHead.astro';
import SharedCSS from '../components/SharedCSS.astro';
import SiteNav from '../components/SiteNav.astro';

const models = [
  {
    name: 'Hiring',
    desc: 'We source, screen, and place engineers to your qualifications and selection process. A one-time placement fee, and the engineer is your employee.',
    icon: '🎯'
  },
  {
    name: 'Hiring + Employer of Record',
    desc: 'We become the legal employer in Armenia. Compliant contracts, payroll, taxes, and benefits — handled monthly. You direct the work; we own the paperwork.',
    icon: '📋'
  },
  {
    name: 'Full Managed Team',
    desc: 'Recruitment + employment + a Yerevan office, IT, equipment, and on-the-ground HR. A cohesive on-site team that reports to you, run by us.',
    icon: '🏢'
  }
];

const whyArmenia = [
  { stat: '60–70%', label: 'lower cost than hiring the same seniority in Western Europe' },
  { stat: '< 4 weeks', label: 'from a 30-minute brief to a working team on the ground' },
  { stat: '1–3 hrs', label: 'time-zone overlap with the UK, EU, and the Gulf for real-time work' },
  { stat: 'One invoice', label: 'sourcing, contracts, payroll, office, equipment, and HR — combined' }
];

const faqs = [
  { q: 'What does it cost to build an engineering team in Armenia?', a: 'Engineering talent in Armenia typically costs 60–70% less than equivalent seniority in Western Europe. You pay a single monthly rate that can bundle salary, employer taxes, office, equipment, and HR — with no hidden setup fees.' },
  { q: 'How fast can you set up a team?', a: 'From a 30-minute brief, we can have a working team on the ground the same month — typically under four weeks for the first hires, faster for roles where we already have vetted candidates in our network.' },
  { q: 'Do we manage the engineers or do you?', a: 'You direct the work, priorities, and roadmap. We handle everything around it: recruitment, the legal employer relationship, payroll, office, equipment, and local HR. In the Full Managed Team model we also provide on-the-ground people management.' },
  { q: 'Is this the same as an Employer of Record (EOR)?', a: 'EOR is one of the three models we offer. Unlike a pure EOR platform, we also source and vet the engineers and — if you want — run the physical office and team in Yerevan, so you get people plus operations, not just payroll compliance.' },
  { q: 'What happens if a hire does not work out?', a: 'Every placement is backed by a replacement guarantee — a free replacement within the first 90 days, for any reason.' },
  { q: 'Why Armenia specifically?', a: 'Armenia is a fast-growing tech hub (often called the "Silicon Valley of the Caucasus") with a deep pool of engineers, strong English, a favourable tax regime, and a 1–3 hour time-zone overlap with the UK, EU, and the Gulf — closer and more convenient than most offshore options.' }
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Engineering team building & staffing in Armenia',
  provider: { '@type': 'Organization', name: 'ArgusRecruit', url: 'https://argusrecruit.com' },
  areaServed: ['United Kingdom', 'United Arab Emirates', 'Canada', 'Oman', 'Armenia', 'European Union'],
  description: 'Build and run a dedicated engineering team in Yerevan, Armenia — recruitment, Employer of Record, and fully managed on-site teams.'
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SiteHead
    title="Build an Engineering Team in Armenia | ArgusRecruit Engineering Studio"
    description="Build and run a dedicated engineering team in Yerevan, Armenia — recruitment, Employer of Record, and fully managed on-site teams. 60–70% lower cost, live in under 4 weeks."
    lang="en"
    alternates={false}
  />
  <SharedCSS />
  <script type="application/ld+json" set:html={JSON.stringify(serviceLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)}></script>
  <style is:global>
    body { background: var(--navy); }
    .es-container { max-width: 1160px; margin: 0 auto; padding: 0 32px; }
    .eyebrow { display: inline-flex; align-items: center; gap: 10px; font-size: 10px; letter-spacing: 4px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; padding: 7px 18px; border: 1px solid rgba(212,175,55,0.35); border-radius: 999px; background: rgba(212,175,55,0.04); }

    .es-hero { padding: 160px 32px 70px; background: linear-gradient(180deg, rgba(30,65,112,0.55), rgba(42,85,137,0.7)), url('/photo-engineering-studio.jpg') center/cover no-repeat; position: relative; }
    .es-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent, var(--navy)); opacity: 0.55; pointer-events: none; }
    .es-hero-inner { max-width: 880px; margin: 0 auto; position: relative; z-index: 1; }
    .es-hero h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(34px, 5vw, 58px); font-weight: 600; line-height: 1.1; letter-spacing: 1px; text-transform: uppercase; margin: 22px 0 20px; }
    .es-hero h1 .accent { color: var(--primary-gold); font-style: italic; }
    .es-hero p { color: rgba(255,255,255,0.88); font-size: 18px; line-height: 1.65; max-width: 680px; margin-bottom: 30px; }

    .es-stats { background: var(--navy-deep); padding: 46px 32px; border-top: 1px solid rgba(212,175,55,0.12); border-bottom: 1px solid rgba(212,175,55,0.12); }
    .es-stats-grid { max-width: 1160px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .es-stat { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 14px; padding: 22px; }
    .es-stat .num { font-family: 'Space Grotesk', sans-serif; font-size: clamp(24px, 2.6vw, 32px); font-weight: 700; color: var(--primary-gold); line-height: 1; }
    .es-stat .label { color: rgba(255,255,255,0.72); font-size: 13px; line-height: 1.5; margin-top: 8px; }

    .es-section { padding: 80px 32px; }
    .es-section.alt { background: var(--navy-darkest); }
    .es-section-head { max-width: 760px; margin: 0 auto 46px; text-align: center; }
    .es-section-head h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 3.4vw, 40px); font-weight: 600; letter-spacing: 1px; line-height: 1.2; text-transform: uppercase; margin-top: 16px; }
    .es-section-head h2 .accent { color: var(--primary-gold); font-style: italic; }
    .es-section-head p { color: rgba(255,255,255,0.7); margin-top: 14px; font-size: 15px; line-height: 1.7; }

    .es-models { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1160px; margin: 0 auto; }
    .es-model { background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.18); border-radius: 16px; padding: 30px 26px; transition: all 0.25s; }
    .es-model:hover { border-color: rgba(212,175,55,0.45); transform: translateY(-3px); }
    .es-model .icon { font-size: 30px; margin-bottom: 14px; }
    .es-model h3 { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 600; color: var(--white); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
    .es-model p { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.65; }

    .es-faq { max-width: 820px; margin: 0 auto; }
    .es-faq-item { border-bottom: 1px solid rgba(212,175,55,0.15); padding: 22px 0; }
    .es-faq-item summary { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; color: var(--white); display: flex; justify-content: space-between; gap: 20px; cursor: pointer; list-style: none; }
    .es-faq-item summary::-webkit-details-marker { display: none; }
    .es-faq-item summary::after { content: '+'; color: var(--primary-gold); font-size: 24px; font-weight: 300; transition: transform 0.3s; }
    .es-faq-item[open] summary::after { transform: rotate(45deg); }
    .es-faq-item p { color: rgba(255,255,255,0.72); font-size: 15px; line-height: 1.75; margin-top: 14px; }

    .es-cta { text-align: center; padding: 80px 32px; background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(30,65,112,0.4)); }
    .es-cta h2 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 3.4vw, 40px); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    .es-cta p { color: rgba(255,255,255,0.75); margin: 16px auto 28px; max-width: 560px; font-size: 16px; line-height: 1.7; }
    .btn-gold { display: inline-block; background: var(--primary-gold); color: var(--navy-darkest); padding: 15px 34px; border-radius: 999px; font-weight: 700; letter-spacing: 0.5px; text-decoration: none; }
    .btn-gold:hover { background: var(--dark-gold); color: var(--white); }

    @media (max-width: 900px) { .es-stats-grid { grid-template-columns: repeat(2, 1fr); } .es-models { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .es-hero { padding: 130px 20px 60px; } .es-section { padding: 60px 20px; } .es-stats-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <SiteNav lang="en" pathInLang="/services/" />

  <section class="es-hero">
    <div class="es-hero-inner">
      <span class="eyebrow">Engineering Studio</span>
      <h1>Build Your Engineering Team <span class="accent">in Armenia</span></h1>
      <p>When you need more than a hire — an entire engineering team, already employed, equipped, and operating — we build it and run it from our Yerevan hub. You manage the work; we manage everything else.</p>
      <a href="/services/#contact" class="btn-gold">Talk to Our Consultant</a>
    </div>
  </section>

  <section class="es-stats">
    <div class="es-stats-grid">
      {whyArmenia.map(s => (
        <div class="es-stat"><div class="num">{s.stat}</div><div class="label">{s.label}</div></div>
      ))}
    </div>
  </section>

  <section class="es-section">
    <div class="es-section-head">
      <span class="eyebrow">Three Models</span>
      <h2>From a single hire to a <span class="accent">fully managed team</span></h2>
      <p>Start with placement, add Employer of Record, or hand us the whole operation. You can move up the ladder as your team in Armenia grows.</p>
    </div>
    <div class="es-models">
      {models.map(m => (
        <div class="es-model">
          <div class="icon">{m.icon}</div>
          <h3>{m.name}</h3>
          <p>{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="es-section alt">
    <div class="es-section-head">
      <span class="eyebrow">Why Armenia</span>
      <h2>The nearshore hub <span class="accent">most teams overlook</span></h2>
      <p>Armenia is one of the fastest-growing tech hubs in the region — deep engineering talent, strong English, a favourable tax regime, and a 1–3 hour overlap with the UK, EU, and the Gulf. Closer and more convenient than most offshore options, at a fraction of Western-Europe cost.</p>
    </div>
  </section>

  <section class="es-section">
    <div class="es-section-head">
      <span class="eyebrow">Common Questions</span>
      <h2>Building an engineering team in <span class="accent">Armenia</span></h2>
    </div>
    <div class="es-faq">
      {faqs.map((f, i) => (
        <details class="es-faq-item" open={i === 0}>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="es-cta">
    <h2>Ready to build in Yerevan?</h2>
    <p>Give us a 30-minute brief and we'll come back with a plan, a timeline, and a cost. All conversations are confidential.</p>
    <a href="/services/#contact" class="btn-gold">Start the Conversation</a>
  </section>

  <footer style="text-align:center; padding: 40px 20px; color: rgba(255,255,255,0.5); font-size: 13px; background: var(--navy-darkest);">© 2026 ArgusRecruit · <a style="color:var(--primary-gold)" href="/">Home</a> · <a style="color:var(--primary-gold)" href="/services/">Services</a> · <a style="color:var(--primary-gold)" href="/privacy/">Privacy</a></footer>
</body>
</html>
