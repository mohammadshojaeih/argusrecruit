---
// Shared styles for blog pages (subset of the main site CSS).
---
<style is:global>
:root {
  --primary-gold: #D4AF37; --dark-gold: #B8860B; --white: #FFFFFF;
  --navy: #1E4170; --navy-deep: #16345A; --navy-soft: #2A5589; --navy-darkest: #0E2440;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Manrope', system-ui, sans-serif; background: var(--navy); color: var(--white); line-height: 1.6; -webkit-font-smoothing: antialiased; }
a { color: inherit; text-decoration: none; }

.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: #081E3E; border-bottom: 1px solid rgba(212,175,55,0.15); }
.nav-inner { max-width: 1440px; margin: 0 auto; padding: 8px 40px; display: flex; align-items: center; justify-content: space-between; gap: 32px; }
.brand { display: flex; align-items: center; gap: 14px; }
.brand img { height: 64px; width: auto; display: block; }
.brand-text { display: flex; flex-direction: column; justify-content: center; padding-left: 14px; border-left: 1px solid rgba(212,175,55,0.3); min-height: 44px; line-height: 1.1; }
.brand-text .tag { font-size: 11px; letter-spacing: 2.5px; color: var(--primary-gold); text-transform: uppercase; font-weight: 600; line-height: 1.3; }
.brand-text .tag-sub { font-size: 8.5px; letter-spacing: 2px; color: rgba(255,255,255,0.7); text-transform: uppercase; font-weight: 500; margin-top: 4px; line-height: 1.3; }
.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a { font-size: 14px; font-weight: 500; opacity: 0.9; position: relative; padding: 6px 0; color: var(--white); }
.nav-links a.active { color: var(--primary-gold); }
.nav-cta { display: inline-flex; align-items: center; justify-content: center; background: var(--primary-gold); color: var(--navy-darkest) !important; padding: 14px 44px; border-radius: 4px; font-weight: 600; font-size: 14px; letter-spacing: 0.3px; min-width: 160px; border: 1px solid var(--primary-gold); transition: all 0.2s; white-space: nowrap; line-height: 1; }
.nav-cta:hover { background: var(--white); border-color: var(--white); }
.back-link { font-size: 13px; color: var(--primary-gold); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }

.lang-switcher { position: relative; display: inline-flex; align-items: center; margin-left: 16px; }
.lang-current { display: inline-flex; align-items: center; gap: 6px; background: transparent; border: 1px solid rgba(212,175,55,0.35); color: #fff; padding: 8px 12px; border-radius: 4px; font-size: 18px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
.lang-current:hover { border-color: #D4AF37; }
.lang-current::after { content: '▾'; font-size: 10px; opacity: 0.7; }
.lang-menu { position: absolute; top: calc(100% + 6px); right: 0; background: #081E3E; border: 1px solid rgba(212,175,55,0.25); border-radius: 4px; min-width: 130px; padding: 4px 0; opacity: 0; pointer-events: none; transform: translateY(-4px); transition: all 0.2s; z-index: 20; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
.lang-switcher.open .lang-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
.lang-menu a { display: block; padding: 10px 14px; font-size: 12px; font-weight: 500; letter-spacing: 0.5px; color: #fff; }
.lang-menu a:hover { background: rgba(212,175,55,0.1); color: #D4AF37; }
.lang-menu a.active { color: #D4AF37; font-weight: 700; }
.lang-menu a.active::before { content: '✓ '; }

footer { background: var(--navy-darkest); padding: 40px 32px; text-align: center; font-size: 13px; color: rgba(255,255,255,0.45); border-top: 1px solid rgba(212,175,55,0.15); }
footer a { color: var(--primary-gold); }

@media (max-width: 960px) { .nav-inner { padding: 6px 20px; } .brand img { height: 52px; } .brand-text { display: none; } .nav-links a:not(.nav-cta) { display: none; } }
</style>
